# ──────────────────────────────────────────────────────────────
# AximaVPN PRODUCTION env. Copy to .env on the VPS and fill values.
# Generate secrets:
#   ENCRYPTION_KEY:  openssl rand -hex 32
#   JWT_* secrets:   openssl rand -hex 48
# ──────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Domain / TLS ──
PANEL_DOMAIN=freedome.aximatech.ru
ACME_EMAIL=admin@aximatech.ru

# Public URLs (API is served under /api on the same domain)
PANEL_PUBLIC_URL=https://freedome.aximatech.ru/api
WEB_PUBLIC_URL=https://freedome.aximatech.ru
NEXT_PUBLIC_API_URL=https://freedome.aximatech.ru/api
CORS_ORIGINS=https://freedome.aximatech.ru

# ── API ──
API_PORT=4000

# ── PostgreSQL ──
POSTGRES_USER=axima
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=aximavpn
DATABASE_URL=postgresql://axima:CHANGE_ME_strong_db_password@postgres:5432/aximavpn?schema=public

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Auth / JWT ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_48
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── Encryption (peer keys, agent tokens) ──
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Default admin (created by seed) ──
ADMIN_EMAIL=admin@aximatech.ru
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── WireGuard defaults ──
WG_SUBNET_CIDR=10.66.66.0/24
WG_SERVER_ADDRESS=10.66.66.1/24
WG_DNS=1.1.1.1
WG_DEFAULT_ENDPOINT_PORT=51820

# Agent bundle path inside the api container (set by the Dockerfile; override only if needed)
# AGENT_BUNDLE_PATH=/repo/apps/agent/dist/index.js

# ── Telegram notifications (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Payments ──
PAYMENT_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
